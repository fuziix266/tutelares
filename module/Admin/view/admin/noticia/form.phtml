<script>
    function validateAntesDePublicar() {
        const title   = document.getElementById('titulo').value.trim();
        const resumen = document.getElementById('resumen').value.trim();
        const content = document.getElementById('contenido').value.trim();
        const img     = document.getElementById('imagen').value.trim();
        
        // El botón de guardar debe funcionar siempre, las alertas son preventivas
        if (!title || !resumen || !content || !img) {
            return confirm("Hay campos que podrían estar vacíos. ¿Deseas Guardar de todas formas?");
        }

        return true;
    }

    function showPreview(type) {
        document.querySelectorAll('.preview-container').forEach(c => c.classList.remove('active'));
        document.querySelectorAll('.preview-tab').forEach(t => t.classList.remove('active'));
        document.getElementById('preview-' + type).classList.add('active');
        event.currentTarget.classList.add('active');
    }

    function updatePreview() {
        const title   = document.getElementById('titulo').value || 'Título de la noticia';
        const resumen = document.getElementById('resumen').value || 'Resumen breve de la noticia...';
        const img     = document.getElementById('imagen').value || 'https://via.placeholder.com/600x400?text=Imagen+Noticia';
        const cat     = document.getElementById('categoria').value;
        const autor   = document.getElementById('autor').value || 'Redacción';

        // Web
        document.getElementById('view-web-title').innerText = title;
        document.getElementById('view-web-resumen').innerText = resumen;
        document.getElementById('view-web-img').src = img;
        document.getElementById('view-web-cat').innerText = cat;
        document.getElementById('view-web-autor').innerText = 'Por: ' + autor;

        // FB
        document.getElementById('view-fb-title').innerText = title;
        document.getElementById('view-fb-message').innerText = title + "\n\n" + resumen;
        document.getElementById('view-fb-img').src = img;

        // IG
        document.getElementById('view-ig-img').src = img;
        document.getElementById('view-ig-caption').innerText = title + ": " + resumen;
    }

    ['titulo', 'resumen', 'contenido', 'imagen', 'categoria', 'autor'].forEach(id => {
        const el = document.getElementById(id);
        if(el) el.addEventListener('input', updatePreview);
    });

    const fijadaCheck = document.getElementById('fijada');
    if (fijadaCheck) {
        fijadaCheck.addEventListener('change', function(e) {
            <?php if ($this->fijadaActual && (!isset($n['id']) || $this->fijadaActual['id'] != $n['id'])): ?>
            if (this.checked) {
                const confirmed = confirm("Ya existe una noticia marcada como ÚLTIMA HORA (#<?= $this->fijadaActual['id'] ?>). Si continúas, la otra dejará de ser destacada automáticamente. ¿Deseas proceder?");
                if (!confirmed) {
                    this.checked = false;
                }
            }
            <?php endif; ?>
        });
    }

    updatePreview();
</script>
