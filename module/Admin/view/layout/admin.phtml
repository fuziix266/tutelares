        <li><a href="<?= $this->url('admin-publisher') ?>"><i class="bi bi-newspaper"></i> Mis Noticias</a></li>
        <li><a href="<?= $this->url('admin-publisher', ['action' => 'crear']) ?>"><i class="bi bi-plus-square"></i> Nueva Noticia</a></li>
    </ul>
