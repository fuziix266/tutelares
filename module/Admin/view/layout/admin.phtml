    <div class="sidebar-label">Portal</div>
    <ul class="sidebar-nav">
        <li><a href="<?= $this->url('home') ?>" target="_blank"><i class="bi bi-globe"></i> Ver Portal</a></li>
    </ul>

    <div class="sidebar-footer">
        <a href="<?= $this->url('admin-logout') ?>">
            <i class="bi bi-box-arrow-left"></i> Cerrar Sesión (<?= htmlspecialchars($usuario) ?>)
        </a>
