    <?php if ($rol === 'radio' || $rol === 'super'): ?>
    <div class="sidebar-label">Radio</div>
    <ul class="sidebar-nav">
        <li><a href="<?= $this->url('admin-radio') ?>"><i class="bi bi-broadcast"></i> Programación</a></li>
    </ul>
