<?php
$noticias = $this->noticias ?? [];
?>
<div class="section container">
    <div class="section-header">
        <h2>Listado de Noticias</h2>
    </div>
    <div class="news-grid">
        <?php if (count($noticias) > 0): ?>
            <?php foreach ($noticias as $n): ?>
            <article class="news-card">
                <div class="news-card-img">
                    <img src="<?= htmlspecialchars($n['imagen'] ?: 'https://via.placeholder.com/600x400?text=Tutelares') ?>" alt="<?= htmlspecialchars($n['titulo']) ?>" loading="lazy">
                    <span class="news-card-cat"><?= htmlspecialchars($n['categoria']) ?></span>
                </div>
                <div class="news-card-body">
                    <h3 class="news-card-title"><?= htmlspecialchars($n['titulo']) ?></h3>
                    <p style="font-size:.9rem;color:#666;line-height:1.6;"><?= htmlspecialchars($n['resumen'] ?: substr(strip_tags($n['contenido']), 0, 150)) ?></p>
                    <div class="news-card-meta">
                        <span><i class="bi bi-person"></i> <?= htmlspecialchars($n['autor'] ?: 'Redacción') ?></span>
                        <span><i class="bi bi-clock"></i> <?= date('d/m/Y', strtotime($n['creado_en'])) ?></span>
                    </div>
                </div>
            </article>
            <?php endforeach; ?>
        <?php else: ?>
            <p>Aún no hay noticias publicadas.</p>
        <?php endif; ?>
    </div>
</div>
